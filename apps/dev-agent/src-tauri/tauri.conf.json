{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DevLoop Agent",
  "version": "0.1.0",
  "identifier": "com.devloop.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevLoop Agent",
        "width": 1280,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
